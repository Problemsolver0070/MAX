# =============================================================================
# Max AI Agent — Environment Variables
# =============================================================================
# Copy to .env and fill in values:  cp .env.example .env
#
# For docker-compose local dev, PostgreSQL and Redis settings are overridden
# by the compose environment block — only POSTGRES_PASSWORD needs a value.
# =============================================================================

# ── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=              # Leave empty for direct Anthropic API; set for Azure AI Foundry
POSTGRES_PASSWORD=changeme

# ── PostgreSQL (overridden by docker-compose for local dev) ─────────────────
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=max
# POSTGRES_USER=max

# ── Redis (overridden by docker-compose for local dev) ──────────────────────
# REDIS_URL=redis://localhost:6379/0

# ── Logging ─────────────────────────────────────────────────────────────────
# MAX_LOG_LEVEL=DEBUG

# ── Owner Identity ──────────────────────────────────────────────────────────
# MAX_OWNER_TELEGRAM_ID=
# MAX_OWNER_WHATSAPP_ID=

# ── Telegram Bot ────────────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=

# ── Webhook (production) ────────────────────────────────────────────────────
# COMM_WEBHOOK_ENABLED=false
# COMM_WEBHOOK_URL=
# COMM_WEBHOOK_SECRET=

# ── Voyage AI (embeddings) ──────────────────────────────────────────────────
# VOYAGE_API_KEY=

# ── Email (SMTP/IMAP) ──────────────────────────────────────────────────────
# EMAIL_SMTP_HOST=
# EMAIL_SMTP_PORT=587
# EMAIL_IMAP_HOST=
# EMAIL_USER=
# EMAIL_PASSWORD=

# ── Calendar (CalDAV) ──────────────────────────────────────────────────────
# CALDAV_URL=
# CALDAV_USER=
# CALDAV_PASSWORD=

# ── Web Search ──────────────────────────────────────────────────────────────
# BRAVE_SEARCH_API_KEY=

# ── API Server ──────────────────────────────────────────────────────────────
# MAX_HOST=0.0.0.0
# MAX_PORT=8080
# MAX_API_KEYS=

# ── Observability ───────────────────────────────────────────────────────────
# OTEL_ENABLED=false
# OTEL_SERVICE_NAME=max
# OTEL_EXPORTER_ENDPOINT=

# ── Azure ───────────────────────────────────────────────────────────────────
# AZURE_KEY_VAULT_URL=
